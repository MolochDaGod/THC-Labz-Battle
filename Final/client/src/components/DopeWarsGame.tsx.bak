  // Admin wallet addresses
  const adminWallets = ['98jzgFFkPhrw9sfr5YyttTpCBiJyid6tzxxJjXrj7xXK', 'ErSGeWkLuKqmW2MNrcFWPsYryNPXDW224GmgNBf8ZT65', 'Fyfu65hZv3npv6wChMFQXqjUfc2hWmq3mGSZbVLDJc9n'];
